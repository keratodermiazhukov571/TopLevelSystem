# --- Clean ---

clean:
	rm -rf $(BUILD_DIR)
	rm -f $(MOD_DIR)/*.so

# --- Install ---

install: all
	install -d $(PREFIX)/bin
	install -d /usr/lib/portal/modules
	install -d /etc/portal
	install -m 755 $(PORTAL) $(PREFIX)/bin/portal
	install -m 755 $(PORTALCTL) $(PREFIX)/bin/portalctl
	install -m 644 $(MOD_CLI) /usr/lib/portal/modules/
	install -m 644 $(MOD_NODE) /usr/lib/portal/modules/
	@# Install all built modules
	@for mod in $(MOD_ALL); do \
		install -m 644 $$mod /usr/lib/portal/modules/; \
	done
	install -m 644 etc/portal.service /etc/systemd/system/portal.service
	install -m 644 etc/portal-devtest.service /etc/systemd/system/portal-devtest.service
	install -m 644 etc/portal-devtest2.service /etc/systemd/system/portal-devtest2.service
	@# Create default instance if it doesn't exist
	@test -d /etc/portal/default || $(PREFIX)/bin/portal -C default >/dev/null 2>&1 || true
	@# Update all instances with missing module configs
	@$(PREFIX)/bin/portal -U 2>/dev/null || true
	@echo ""
	@echo "Installed. 45 modules in /usr/lib/portal/modules/"
	@echo ""
	@echo "  Create instance:  portal -C <name>"
	@echo "  Delete instance:  portal -D <name>"
	@echo "  Start instance:   portal -n <name> -f -d"
	@echo "  Connect CLI:      portal -n <name> -r"
	@echo ""
	@echo "  Systemd:   systemctl enable portal-<name>"
	@echo "             systemctl start portal-<name>"

# --- Dev test instance ---

devtest: install
	@echo "Setting up devtest instance..."
	@install -d /etc/portal/devtest /etc/portal/devtest/users /etc/portal/devtest/groups /etc/portal/devtest/modules
	@test -f /etc/portal/devtest/portal.conf || cp etc/devtest.conf /etc/portal/devtest/portal.conf
	@test -f /etc/portal/devtest/users/root.conf || printf "password = portal\napi_key = auto\ngroups = root\n" > /etc/portal/devtest/users/root.conf
	@test -f /etc/portal/devtest/users/admin.conf || printf "password = admin\napi_key = auto\ngroups = admin,dev\n" > /etc/portal/devtest/users/admin.conf
	@echo ""
	@echo "Devtest instance ready. Run with:"
	@echo "  portal -n devtest -f -d"
	@echo "  portal -n devtest -r"

devtest2: install
	@echo "Setting up devtest2 instance..."
	@install -d /etc/portal/devtest2 /etc/portal/devtest2/users /etc/portal/devtest2/groups /etc/portal/devtest2/modules
	@cp etc/devtest2.conf /etc/portal/devtest2/portal.conf
	@test -f /etc/portal/devtest2/users/root.conf || printf "password = portal\napi_key = auto\ngroups = root\n" > /etc/portal/devtest2/users/root.conf
	@echo ""
	@echo "Devtest2 instance ready. Run with:"
	@echo "  portal -n devtest2 -f -d"
	@echo "  portal -n devtest2 -r"
