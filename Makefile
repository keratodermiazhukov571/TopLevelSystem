# --- Tools ---

tools: $(PORTALCTL)

$(PORTALCTL): $(TOOLS_DIR)/portalctl.c
	@mkdir -p $(BUILD_DIR)
	@echo "  CC    $@"
	@$(CC) $(CFLAGS) -o $@ $<

# --- Tests ---

tests: $(TEST_PATH) $(TEST_ACL) $(TEST_HT) $(TEST_PUBSUB) $(TEST_WIRE) $(TEST_EVENTS) $(TEST_EVLOOP) $(TEST_CRYPTO) $(TEST_VALID)
	@echo ""
	@echo "Running tests..."
	@echo "================"
	@$(TEST_PATH)
	@echo ""
	@$(TEST_ACL)
	@echo ""
	@$(TEST_HT)
	@echo ""
	@$(TEST_PUBSUB)
	@echo ""
	@$(TEST_WIRE)
	@echo ""
	@$(TEST_EVENTS)
	@echo ""
	@$(TEST_EVLOOP)
	@echo ""
	@$(TEST_CRYPTO)
	@echo ""
	@$(TEST_VALID)

$(TEST_CRYPTO): $(TESTS_DIR)/test_crypto.c $(LIB_DIR)/sha256/sha256.c
	@mkdir -p $(BUILD_DIR)
	@echo "  CC    $@"
	@$(CC) $(CFLAGS) -Ilib/sha256 -o $@ $^

$(TEST_VALID): $(TESTS_DIR)/test_validator.c
