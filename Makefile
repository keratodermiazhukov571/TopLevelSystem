$(TEST_EVLOOP): $(TESTS_DIR)/test_eventloop.c $(CORE_DIR)/core_event.c $(CORE_DIR)/core_hashtable.c $(CORE_DIR)/core_log.c $(LIBEV_OBJ)
	@mkdir -p $(BUILD_DIR)
	@echo "  CC    $@"
	@$(CC) $(CFLAGS) -Ilib/libev -o $@ $^ -lm

